{
  "name": "survey-report",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "slidev slides.md --host 0.0.0.0 --base /survey-report/ --router-mode hash",
    "extract": "node scripts/extract-claude-report.mjs",
    "build:slidev": "slidev build slides.md --base /survey-report/ --out /tmp/survey-report-slidev-dist --router-mode hash",
    "build": "node scripts/build-site.mjs",
    "check": "node scripts/check-report.mjs",
    "deploy": "npm run build && npm run check && gh workflow run \"Deploy Pages\" --ref main"
  },
  "dependencies": {
    "@slidev/cli": "^52.0.0",
    "@slidev/theme-default": "^0.25.0",
    "gh-pages": "^6.3.0"
  }
}
